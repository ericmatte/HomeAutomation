# =============================================================================
# Secrets & credentials
# =============================================================================
secrets.yaml
secrets.py
*.secret.*
*auth.json
/html5_push_registrations.conf
/known_devices.yaml
/www/google*.html

# =============================================================================
# Certificates
# =============================================================================
*.pem
acme_reg.json

# =============================================================================
# Home Assistant runtime files (logs, database, generated state)
# =============================================================================
/.uuid
/home-assistant_v2.db*
/home-assistant.log*
/options.xml
/tts
.cache

# Ignore all internal storage except the Lovelace dashboards we want to track
/.storage/**
!/.storage/lovelace*

# =============================================================================
# Z-Wave
# =============================================================================
/OZW_Log.txt
pyozw.sqlite
zwcfg_0xdd825656.xml
zwscene.xml

# =============================================================================
# Zigbee2MQTT
# =============================================================================
zigbee.*
zigbee2mqtt/

# =============================================================================
# Custom components & community frontend resources
# =============================================================================
/custom_components
/www/community

# =============================================================================
# Themes — ignore everything except the ones we maintain
# =============================================================================
/themes/*
!/themes/my-themes
!/themes/minimalist-desktop/minimalist-desktop.yaml

# =============================================================================
# AppDaemon — only track config and our apps directory
# =============================================================================
/appdaemon/*
!/appdaemon/appdaemon.yaml
!/appdaemon/apps
/appdaemon/apps/*
!/appdaemon/apps/apps.yaml

# =============================================================================
# Miscellaneous
# =============================================================================
image/
*.pyc

